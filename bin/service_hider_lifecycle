#!/system/bin/sh

SCRIPT_DIR="${0%/*}"
MODDIR="${SCRIPT_DIR%/*}"
CTL="${MODDIR}/bin/service_hider_ctl"
LOG_BASE="/data/adb/hyperpatch_logs"
LOG_FILE="${LOG_BASE}/service_hider.log"

# 创建日志目录和文件
mkdir_log() {
    mkdir -p "$LOG_BASE" 2>/dev/null
    touch "$LOG_FILE" 2>/dev/null
}

# 记录带有时间戳的消息到日志文件
log_msg() {
    printf '%s [HyperPatch][ServiceHider] %s\n' \
        "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo '[no-time]')" \
        "$1" >> "$LOG_FILE" 2>/dev/null
}

# 检查日志文件大小 超过限制则进行轮换
rotate_log() {
    [ -f "$LOG_FILE" ] || return 0
    size=$(wc -c < "$LOG_FILE" 2>/dev/null); [ -z "$size" ] && size=0
    if [ "$size" -ge $((512 * 1024)) ]; then
        mv -f "${LOG_FILE}.1" "${LOG_FILE}.2" 2>/dev/null
        mv -f "$LOG_FILE"     "${LOG_FILE}.1" 2>/dev/null
    fi
}

# 轮询系统属性直到设备完成启动
wait_for_boot() {
    until [ "$(getprop sys.boot_completed)" = "1" ]; do
        sleep 2
    done
}

# 调用控制脚本恢复所有网络规则
restore_rules() {
    "${CTL}" restore >/dev/null 2>&1
}

# 服务的早期启动入口 负责开机后一次性恢复规则
run_service() {
    mkdir_log
    rotate_log
    log_msg "service hook entered"

    if [ "$SERVICE_HIDER_BOOT_READY" != "1" ]; then
        wait_for_boot
    fi

    log_msg "restoring rules (boot apply only)"
    if restore_rules; then
        log_msg "restore ok (boot apply only)"
    else
        log_msg "restore failed (boot apply only)"
    fi
}

# 在模块卸载时清理进程并恢复网络规则
run_uninstall() {
    log_msg "uninstall hook entered"

    # 将链的卸载委托给 ctl 以避免重复编写 iptables 包装逻辑
    "${CTL}" uninstall
}

# 主执行分支 解析外部参数执行特定的阶段指令
case "$1" in
    service)
        run_service
        ;;
    uninstall)
        run_uninstall
        ;;
    *)
        echo "Usage: $0 {service|uninstall}"
        exit 1
        ;;
esac
